# Clothing Ecommerce Baseline — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ─── Brand Identity ───────────────────────────────────────────────
BRAND_NAME="Elder"
BRAND_TAGLINE="Indigenous Streetwear"
BRAND_COLOR_PRIMARY="#1A1A1A"
BRAND_COLOR_ACCENT="#C53030"
BRAND_COLOR_BACKGROUND="#FAFAFA"
BRAND_COLOR_TEXT="#111111"
BRAND_LOGO_PATH="/images/brand/logo.png"
BRAND_FAVICON_PATH="/images/brand/favicon.ico"

# Next.js build-time vars (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_BRAND_NAME="Elder"
NEXT_PUBLIC_BRAND_TAGLINE="Indigenous Streetwear"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────────────
DATABASE_PATH=./data/store.db

# ─── Authentication ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
ADMIN_JWT_LIFETIME_HOURS=8

# ─── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Shipping ────────────────────────────────────────────────────
SHIPPING_FLAT_RATE_CENTS=1200
SHIPPING_FREE_THRESHOLD_CENTS=15000
SHIPPING_DESCRIPTION="Flat rate shipping across Canada"

# ─── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM="Elder <orders@example.com>"

# ─── Store Configuration ─────────────────────────────────────────
ORDER_NUMBER_PREFIX=ELD
STORE_DOMAIN=http://localhost:3000
STORE_CURRENCY=CAD
TAX_RATE=0.13

# ─── Container / Compose ─────────────────────────────────────────
COMPOSE_CONTAINER_PREFIX=elder
COMPOSE_PROJECT_NAME=elder
API_PORT=8100
STOREFRONT_PORT=3000

# ─── Development ──────────────────────────────────────────────────
DEV_MODE=true
