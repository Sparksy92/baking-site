# Cedar & Sage Homestead Vercel-Lite Environment Variables
# Copy this file to .env and fill in the values for local development.
# Configure these variables in your Vercel Project Settings for production.

# --- Database (Neon Postgres) ---
# Direct connection string for server-side PostgreSQL queries
DATABASE_URL="postgres://user:password@ep-host-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Admin Authentication ---
# Secret key used for signing session cookies
ADMIN_SESSION_SECRET="generate-a-secure-random-string-at-least-32-characters"
# The login email address for the admin panel
ADMIN_EMAIL="admin@cedarandsagehomestead.ca"
# Hashed password for the admin panel. 
# Run `node -e "console.log(require('crypto').pbkdf2Sync('YOUR_PASSWORD', 'cedar-salt-homestead', 1000, 64, 'sha512').toString('hex'))"` to generate this.
# The hash below corresponds to the default password: admin123
ADMIN_PASSWORD_HASH="b1a20bf155239e240212f45ec926719cd227eb0d507119ecb001a1db6c1bf9eb9d5929532ea4a5690bfa3fcd6d8174f84a4a581458dc6b4b455b5f2cd796f6e5"

# --- Business Info & Email ---
# Contact email where order request notifications are sent
CONTACT_EMAIL="hello@cedarandsagehomestead.ca"
# Payment email where customers will send e-transfers
ETRANSFER_EMAIL="payments@cedarandsagehomestead.ca"

# --- Resend Email Configuration (Optional) ---
# API key from resend.com to enable automated email alerts
RESEND_API_KEY="re_123456789"
# The verified sender email in your Resend account
EMAIL_FROM="Cedar & Sage Homestead <orders@cedarandsagehomestead.ca>"

# --- Public Frontend Config ---
NEXT_PUBLIC_SITE_NAME="Cedar & Sage Homestead"
NEXT_PUBLIC_SITE_URL="https://cedar-sage.vercel.app"
